{
  "info": {
    "name": "APTIS-134 Batch API Tests",
    "description": "Test collection for batch status, clone, and export-report endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:3010/api"
    },
    {
      "key": "sessionId1",
      "value": "REPLACE_WITH_REAL_SESSION_ID_1"
    },
    {
      "key": "sessionId2",
      "value": "REPLACE_WITH_REAL_SESSION_ID_2"
    },
    {
      "key": "fakeId",
      "value": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "item": [
    {
      "name": "0. Setup - Get All Sessions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/sessions/all",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "all"]
        },
        "description": "Get all sessions to copy real IDs into collection variables sessionId1 and sessionId2"
      }
    },
    {
      "name": "BATCH STATUS",
      "item": [
        {
          "name": "1.1 All Success (200)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{sessionId2}}\"],\n  \"status\": \"COMPLETE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/status",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "status"]
            },
            "description": "Expected: 200 - All sessions updated successfully"
          }
        },
        {
          "name": "1.2 Partial Failure (207)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{fakeId}}\"],\n  \"status\": \"NOT_STARTED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/status",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "status"]
            },
            "description": "Expected: 207 - One success, one failure (fake ID not found)"
          }
        },
        {
          "name": "1.3 All Fail (400)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{fakeId}}\"],\n  \"status\": \"COMPLETE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/status",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "status"]
            },
            "description": "Expected: 400 - All sessions failed (fake IDs)"
          }
        },
        {
          "name": "1.4 Invalid Status (400)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\"],\n  \"status\": \"INVALID_STATUS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/status",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "status"]
            },
            "description": "Expected: 400 - Invalid status value"
          }
        },
        {
          "name": "1.5 Empty Array (400)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [],\n  \"status\": \"COMPLETE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/status",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "status"]
            },
            "description": "Expected: 400 - Empty sessionIds array"
          }
        }
      ]
    },
    {
      "name": "BATCH CLONE",
      "item": [
        {
          "name": "2.1 All Success (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{sessionId2}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/clone",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "clone"]
            },
            "description": "Expected: 201 - All sessions cloned with (Copy) suffix and new key"
          }
        },
        {
          "name": "2.2 Partial Failure (207)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{fakeId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/clone",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "clone"]
            },
            "description": "Expected: 207 - One cloned, one failed (fake ID)"
          }
        },
        {
          "name": "2.3 All Fail (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{fakeId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/clone",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "clone"]
            },
            "description": "Expected: 400 - All failed"
          }
        },
        {
          "name": "2.4 Empty Array (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/clone",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "clone"]
            },
            "description": "Expected: 400 - Empty array"
          }
        }
      ]
    },
    {
      "name": "BATCH EXPORT REPORT",
      "item": [
        {
          "name": "3.1 All Success (200)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{sessionId2}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/export-report",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "export-report"]
            },
            "description": "Expected: 200 - Reports generated with participant scores"
          }
        },
        {
          "name": "3.2 Partial Failure (207)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{sessionId1}}\", \"{{fakeId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/export-report",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "export-report"]
            },
            "description": "Expected: 207 - One report generated, one failed"
          }
        },
        {
          "name": "3.3 All Fail (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": [\"{{fakeId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/export-report",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "export-report"]
            },
            "description": "Expected: 400 - All failed"
          }
        },
        {
          "name": "3.4 Empty Array (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/batch/export-report",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "batch", "export-report"]
            },
            "description": "Expected: 400 - Empty array"
          }
        }
      ]
    },
    {
      "name": "VERIFY",
      "item": [
        {
          "name": "4.1 Get All Sessions (verify changes)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/all",
              "host": ["{{baseUrl}}"],
              "path": ["sessions", "all"]
            },
            "description": "Verify cloned sessions exist and status changes applied"
          }
        }
      ]
    }
  ]
}
