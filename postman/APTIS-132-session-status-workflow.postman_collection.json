{
  "info": {
    "name": "APTIS-132 Session Status Workflow",
    "_postman_id": "aptis-132-session-status",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:3010/api"
    },
    {
      "key": "sessionId",
      "value": "17e76c71-2858-4708-baba-6d31fbf8d9b6"
    }
  ],
  "item": [
    {
      "name": "Test 1: COMPLETE → PUBLISHED (valid)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "{{sessionId}}", "status"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"status\": \"PUBLISHED\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status is PUBLISHED', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.status).to.eql('PUBLISHED');",
              "  pm.expect(json.message).to.include('COMPLETE to PUBLISHED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Test 2: PUBLISHED → DRAFT (invalid)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "{{sessionId}}", "status"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"status\": \"DRAFT\" }"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Invalid transition message', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.include('Cannot transition from PUBLISHED to DRAFT');",
              "});"
            ]
          }
        }
      ]
    },
